packages:
  yum:
    python3-pip: []

container_commands:
  01_pip_install:
    command: "pip install -r requirements.txt"
  02_migrate:
    command: "python manage.py migrate --noinput"
  03_collectstatic:
    command: "python manage.py collectstatic --noinput"
  04_media_folder:
    command: "mkdir -p /var/app/current/media/imagenes && chmod -R 775 /var/app/current/media"